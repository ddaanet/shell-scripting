{
  "description": "Run shellcheck on shell files after Claude writes or edits them; findings are fed back to Claude via exit 2.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/shellcheck-on-edit.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
